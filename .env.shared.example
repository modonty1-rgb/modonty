# ════════════════════════════════════════════════════════════════════════════
#  MODONTY MONOREPO — SHARED ENVIRONMENT VARIABLES (TEMPLATE)
# ════════════════════════════════════════════════════════════════════════════
#  Copy this file to .env.shared (gitignored) and fill in real values.
#  Loaded by next.config.ts in admin/modonty/console (via dotenv).
#  Priority: <app>/.env.local > <app>/.env > .env.shared
# ════════════════════════════════════════════════════════════════════════════


# ════════════════════════════════════════════════════════════════════════════
#  1. CORE INFRASTRUCTURE
# ════════════════════════════════════════════════════════════════════════════

DATABASE_URL=
AUTH_TRUST_HOST=true
NEXT_PUBLIC_SITE_URL=


# ════════════════════════════════════════════════════════════════════════════
#  2. INTER-APP SECRETS
# ════════════════════════════════════════════════════════════════════════════

REVALIDATE_SECRET=
INTERNAL_LOG_SECRET=


# ════════════════════════════════════════════════════════════════════════════
#  3. OAUTH — GOOGLE SIGN-IN
# ════════════════════════════════════════════════════════════════════════════

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=


# ════════════════════════════════════════════════════════════════════════════
#  4. STORAGE & MEDIA — CLOUDINARY
# ════════════════════════════════════════════════════════════════════════════

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_URL=
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=


# ════════════════════════════════════════════════════════════════════════════
#  5. EMAIL — RESEND
# ════════════════════════════════════════════════════════════════════════════

RESEND_API_KEY=
RESEND_FROM=


# ════════════════════════════════════════════════════════════════════════════
#  6. SEO — SEARCH CONSOLE & PERFORMANCE
# ════════════════════════════════════════════════════════════════════════════

# Legacy service account
GOOGLE_SEARCH_CONSOLE_CLIENT_EMAIL=
GOOGLE_SEARCH_CONSOLE_PRIVATE_KEY=
GOOGLE_SEARCH_CONSOLE_SITE_URL=

# New service account
# GSC_MODONTY_CLIENT_EMAIL — UNUSED (client_email is inside KEY_BASE64 JSON)
GSC_MODONTY_KEY_BASE64=
GSC_MODONTY_PROPERTY=

# PageSpeed Insights
GOOGLE_PAGESPEED_API_KEY=


# ════════════════════════════════════════════════════════════════════════════
#  7. ANALYTICS — GOOGLE TAG MANAGER
# ════════════════════════════════════════════════════════════════════════════

NEXT_PUBLIC_GTM_CONTAINER_ID=
# NEXT_PUBLIC_GTM_DEBUG — UNUSED
# NEXT_PUBLIC_GTM_ENVIRONMENT — UNUSED


# ════════════════════════════════════════════════════════════════════════════
#  8. AI / SEARCH SERVICES
# ════════════════════════════════════════════════════════════════════════════

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.2
COHERE_API_KEY=
SERPER_API_KEY=


# ════════════════════════════════════════════════════════════════════════════
#  9. EXTERNAL APIs
# ════════════════════════════════════════════════════════════════════════════

UNSPLASH_ACCESS_KEY=
NEWS_API_KEY=


# ════════════════════════════════════════════════════════════════════════════
#  10. NOTIFICATIONS — TELEGRAM
# ════════════════════════════════════════════════════════════════════════════

# Admin global bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# Per-client bot
TELEGRAM_CLIENT_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_SECRET=


# ════════════════════════════════════════════════════════════════════════════
